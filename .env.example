# ─── Application ─────────────────────────────────────────────────────────────

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=CHANGE_ME_generate_a_32_byte_hex_secret

# REQUIRED — generate a Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key

# ─── Database ─────────────────────────────────────────────────────────────────

# Async URL (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://finport:finport_dev_password@localhost:5432/finport

# Sync URL (used by Celery workers and Alembic)
# For SQLite local dev:
# DATABASE_URL=sqlite+aiosqlite:///./finport_dev.db

# ─── Redis / Celery ───────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Storage ─────────────────────────────────────────────────────────────────

# "local" or "s3"
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data/uploads

# S3 (only required when STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=finport-statements
# AWS_S3_REGION=us-east-1

# ─── Upload limits ────────────────────────────────────────────────────────────

MAX_UPLOAD_SIZE_MB=50
ALLOWED_MIME_TYPES=application/pdf,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ─── Reconciliation ───────────────────────────────────────────────────────────

RECONCILIATION_AUTO_RESOLVE_CONFIDENCE=0.95

# ─── Logging ─────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ─── CORS (space-separated origins for local dev) ────────────────────────────

CORS_ORIGINS=http://localhost:3000 http://localhost:5173
